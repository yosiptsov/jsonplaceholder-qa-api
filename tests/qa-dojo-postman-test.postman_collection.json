					"name": "filterByMinMaxPrice",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"let minPrice = Number(pm.collectionVariables.get(\"minPrice\"));",
									"let maxPrice = Number(pm.collectionVariables.get(\"maxPrice\"));",
									"let json = pm.response.json();",
									"",
									"pm.test(`All products have price within ${minPrice} and ${maxPrice}`, function () {",
									"    for (const product of json) {",
									"        pm.expect(product.price).to.be.within(minPrice, maxPrice);",
									"    }",
									"});"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
